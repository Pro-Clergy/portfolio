# ─── Public (exposed to browser) ──────────────────────
# Site URL — used for OG metadata, sitemap, canonical links
NEXT_PUBLIC_SITE_URL=https://mathias.dev

# ─── Database (server-side only) ──────────────────────
# MongoDB Atlas connection string (leave blank to use in-memory fallback)
MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/portfolio

# ─── Email / SMTP (server-side only) ──────────────────
# For Gmail: generate an App Password at https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# ─── Contact Form (server-side only) ──────────────────
# Where contact form submissions are emailed to
CONTACT_EMAIL=your-email@gmail.com
